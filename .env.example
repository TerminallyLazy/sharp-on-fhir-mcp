# --
# SHARP-on-MCP context (FHIR)
# --
# Per SHARP §3.2 the agent SHOULD forward these as request headers:
#   X-FHIR-Server-URL, X-FHIR-Access-Token, X-Patient-ID.
# The vars below are an *optional* fallback used when no headers arrive
# (handy for local dev against public FHIR sandboxes). In production, agents
# should always send the headers.
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4
FHIR_ACCESS_TOKEN=
PATIENT_ID=

# Strict mode — when 1/true, tool calls without FHIR context are rejected
# with a `fhir_context_required` ToolError. Default permissive.
SHARP_STRICT_CONTEXT=0

# --
# mem0 clinical memory (Apache-2.0; embedded SDK, no separate service)
# --
# Required for the memory_* tools. mem0 needs an LLM to extract memories
# from input text and an embedder for retrieval. The simplest path is
# OpenAI; for OpenAI-compatible providers (OpenRouter, Ollama OpenAI-mode,
# vLLM, LM Studio, Together) just set OPENAI_API_BASE.
OPENAI_API_KEY=
OPENAI_API_BASE=
# Examples:
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_BASE=http://host.docker.internal:11434/v1   # Ollama on host

# Set MEM0_DISABLED=1 to skip mem0 entirely — the memory_* tools won't be
# registered, the rest of the server still works.
MEM0_DISABLED=0

# Provider + model selection.
MEM0_LLM_PROVIDER=openai           # openai | ollama | litellm
MEM0_LLM_MODEL=gpt-4o-mini
MEM0_EMBED_PROVIDER=openai         # openai | ollama | huggingface
MEM0_EMBED_MODEL=text-embedding-3-small

# Where mem0 persists its vector store + history db. Mounted as a Docker
# volume by docker-compose. Use `chroma` (default) or `qdrant` for an
# embedded file-backed vector store; `pgvector` if you bring your own DB.
MEM0_VECTOR_STORE=chroma
MEM0_DATA_DIR=/data/mem0

# --
# Server / runtime
# --
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Host port mapping (compose-only).
SHARP_HOST_PORT=8000
