# --
# SHARP-on-MCP context (FHIR)
# --
# Per SHARP §3.2 the agent SHOULD forward these as request headers:
#   X-FHIR-Server-URL, X-FHIR-Access-Token, X-Patient-ID.
# The vars below are an *optional* fallback used when no headers arrive
# (handy for local dev against public FHIR sandboxes). In production, agents
# should always send the headers.
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4
FHIR_ACCESS_TOKEN=
PATIENT_ID=

# Strict mode — when 1/true, tool calls without FHIR context are rejected
# with a `fhir_context_required` ToolError. Default permissive.
SHARP_STRICT_CONTEXT=0

# --
# OmniSimpleMem clinical memory (multimodal)
# --
# When OMNIMEM_API_URL is set the `memory_*` tools become available.
# Inside docker-compose this defaults to the internal `omnimem` service.
OMNIMEM_API_URL=http://omnimem:8000
OMNIMEM_API_TOKEN=

# --
# OmniSimpleMem service config (consumed by the omnimem container)
# --
# OPENAI_API_KEY is required for LLM-driven steps (summary / answer /
# captioning / whisper). Set OPENAI_API_BASE to use any OpenAI-compatible
# provider (OpenRouter, Ollama OpenAI-mode, vLLM, LM Studio, Together, etc).
OPENAI_API_KEY=
OPENAI_API_BASE=
# Examples:
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_API_BASE=http://host.docker.internal:11434/v1   # Ollama on host

# Unified LLM model for summary/query/caption.
LLM_MODEL=gpt-4o-mini

# Embedding model — defaults to local sentence-transformers (no OpenAI
# call). Override to OpenAI/compat embeddings only if needed.
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Path mounted into BOTH containers. Drop image/audio/video files here so
# `memory_store_image` etc. can ingest them. Container path: /shared.
SHARED_MEDIA_DIR=./shared

# --
# Server / runtime
# --
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG_MODE=0

# Host port mappings (compose-only).
SHARP_HOST_PORT=8000
OMNIMEM_HOST_PORT=8001
