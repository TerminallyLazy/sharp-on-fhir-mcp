# Optional fallbacks — used when the X-FHIR-Server-URL / X-FHIR-Access-Token
# request headers are not present (handy for local dev against public FHIR
# sandboxes). In production, agents/hosts should always send the headers.
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4
FHIR_ACCESS_TOKEN=
PATIENT_ID=

# Optional SimpleMem-backed clinical memory. If both vars are set, the
# memory_* tools become available. Leave blank to disable.
SIMPLEMEM_API_URL=
SIMPLEMEM_ACCESS_TOKEN=

# Server settings (Vercel sets PORT automatically).
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# When true, the SHARP middleware returns 403 for non-handshake calls that
# arrive without FHIR context headers. Defaults to permissive (false).
# STRICT_CONTEXT=true
